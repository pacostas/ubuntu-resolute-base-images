{
  "support_usns": true,
  "receipts_show_limit": 16,
  "platforms": ["linux/amd64", "linux/arm64"],
  "os_name": "ubuntu",
  "os_codename": "resolute",
  "repo_type": "image",
  "images": [
    {
      "name": "resolute-tiny",
      "config_dir": "images/resolute-tiny-images",
      "output_dir": "builds/resolute-tiny-images",
      "build_image": "build",
      "run_image": "run",
      "stack_type": "tiny",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image-stack_type",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-stack_type-version-arch"
    },
    {
      "name": "resolute-static",
      "config_dir": "images/resolute-static-images",
      "output_dir": "builds/resolute-static-images",
      "build_image": "build",
      "run_image": "run",
      "build_receipt_filename": "build-receipt.cyclonedx.json",
      "run_receipt_filename": "run-receipt.cyclonedx.json",
      "stack_type": "static",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image-stack_type",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-stack_type-version-arch"
    },
    {
      "name": "resolute-base",
      "config_dir": "images/resolute-base-images",
      "output_dir": "builds/resolute-base-images",
      "build_image": "build",
      "run_image": "run",
      "create_build_image": true,
      "stack_type": "base",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-version-arch"
    },
    {
      "name": "resolute-tiny-no-stacks",
      "config_dir": "images/resolute-tiny-images-no-stack-id",
      "output_dir": "builds/resolute-tiny-images-no-stack-id",
      "build_image": "build",
      "run_image": "run",
      "stack_type": "tiny-no-stacks",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image-stack_type",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-stack_type-version-arch",
      "no_stack_id": true
    },
    {
      "name": "resolute-static-no-stacks",
      "config_dir": "images/resolute-static-images-no-stack-id",
      "output_dir": "builds/resolute-static-images-no-stack-id",
      "build_image": "build",
      "run_image": "run",
      "build_receipt_filename": "build-receipt.cyclonedx.json",
      "run_receipt_filename": "run-receipt.cyclonedx.json",
      "stack_type": "static-no-stacks",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image-stack_type",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-stack_type-version-arch",
      "no_stack_id": true
    },
    {
      "name": "resolute-base-no-stacks",
      "config_dir": "images/resolute-base-images-no-stack-id",
      "output_dir": "builds/resolute-base-images-no-stack-id",
      "build_image": "build",
      "run_image": "run",
      "create_build_image": true,
      "stack_type": "no-stacks",
      "pattern_image_registry_name": "os_name-os_codename-build_image_run_image-stack_type",
      "pattern_assets_prefix": "os_name-os_codename-build_image_run_image-stack_type-version-arch",
      "no_stack_id": true
    }
  ]
